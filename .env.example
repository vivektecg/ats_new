# Copy this file to .env for local backend settings.
# Never commit .env because it contains private tokens.

GITHUB_BACKUP_REPO=VivekTECG/ATS_New
GITHUB_BACKUP_TOKEN=paste_new_github_token_here
GITHUB_BACKUP_BRANCH=main
GITHUB_BACKUP_PATH=ats-backups/latest-ats-backup.json
GITHUB_BACKUP_AUTO=true
GITHUB_BACKUP_DEBOUNCE_MS=2500

# Production backend source of truth.
ATS_STORAGE=postgres
DATABASE_URL=postgres://user:password@host:5432/eventus_ats
ATS_SESSION_SECRET=replace_with_a_long_random_secret_32_chars_or_more
ATS_REQUIRE_AUTH=true

# Backend file storage for resumes and candidate documents.
# For production, point this at a persistent disk/volume path.
ATS_FILE_STORAGE_DIR=/var/data/eventus-ats/uploads
ATS_FILE_UPLOAD_MAX_BYTES=26214400
ATS_JSON_BODY_MAX_BYTES=20971520

# Outlook / Microsoft Graph email sending.
# Works on any hosting provider. The app registration is in Microsoft Entra,
# but the ATS backend can run on Render, Railway, DigitalOcean, VPS, AWS, etc.
PUBLIC_API_ORIGIN=http://localhost:8787
FRONTEND_ORIGIN=http://127.0.0.1:5173
OUTLOOK_CLIENT_ID=paste_microsoft_app_client_id_here
OUTLOOK_CLIENT_SECRET=paste_microsoft_app_client_secret_here
OUTLOOK_TENANT_ID=common
OUTLOOK_REDIRECT_URI=http://localhost:8787/api/ats/email/outlook/callback
OUTLOOK_SCOPES=offline_access User.Read Mail.Send
OUTLOOK_TOKEN_ENCRYPTION_KEY=replace_with_a_long_random_secret_32_chars_or_more
